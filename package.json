{
  "name": "gaishan",
  "version": "0.1.0",
  "private": true,
  "description": "Electron video player for language learning with subtitles, dictionary lookups, and pronunciation playback.",
  "author": "alfasi",
  "repository": {
    "type": "git",
    "url": "https://github.com/alfasi/gaishan.git"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "icons": "zsh scripts/generate-icons.sh",
    "dev": "vite",
    "build:player": "vite build",
    "build:extension:content": "vite build --mode extension-content",
    "build:extension:popup": "vite build --mode extension-popup",
    "build:extension": "npm run build:extension:content && npm run build:extension:popup && node scripts/finalize-extension.js",
    "build": "npm run build:player && npm run build:extension",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build:player && npm run icons && electron-builder",
    "electron:build:all": "npm run build:player && npm run icons && electron-builder --mac --linux --win",
    "electron:pack": "npm run build:player && npm run icons && electron-builder --dir"
  },
  "dependencies": {
    "matroska-subtitles": "^3.3.2",
    "opencc-js": "^1.0.5",
    "pinyin-pro": "^3.28.0"
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "electron-icon-builder": "^2.0.1",
    "vite": "^5.4.21",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "build": {
    "appId": "com.gaishan.app",
    "productName": "Gaishan",
    "asar": true,
    "compression": "maximum",
    "afterPack": "./scripts/after-pack.js",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json",
      "!dist/mac*/**",
      "!dist/win*/**",
      "!dist/linux*/**",
      "!release-build/**",
      "!release/**",
      "!example/*.mkv",
      "!**/*.map",
      "!**/README*",
      "!**/CHANGELOG*",
      "!**/test{,s}/**",
      "!**/__tests__/**",
      "!**/tsconfig*.json"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.education",
      "target": "zip"
    },
    "linux": {
      "icon": "build/icons/512x512.png",
      "target": "tar.gz"
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "zip"
    }
  }
}
